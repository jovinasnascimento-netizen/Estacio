#include <stdio.h>

int main() {
    int numero, soma = 0;
    int quantidade = 5;

    for (int i = 1; i <= 10; i++) {
        printf("Digite o %dº numero: ", i);
        scanf("%d", &numero);

        if (numero > 0) {
            soma += numero; // Adiciona o número à soma se for positivo
        }
    }

    printf("\nA soma dos numeros positivos e: %d\n", soma);

    return 0;
}
