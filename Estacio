    scanf("%d", &biometria);

    printf("Digite a senha (1/0): ");
    scanf("%d", &senha);

    printf("Digite o modo seguro (1/0): ");
    scanf("%d", &modoSeguro);


    if (modoSeguro == 1) { 
        if (senha == 1) { 
        printf("Desbloqueado"); 
        } 
    else { 
            printf("Bloqueado"); 
        } 
    } 
    else if (modoSeguro == 0) { 
        if (senha == 1 || biometria == 1) { 
          printf("Desbloqueado"); 
        } 
        else { 
          printf("Bloqueado"); 
        } 
    } 
    else { 
        printf("Bloqueado"); 
    }

    return 0;
}
